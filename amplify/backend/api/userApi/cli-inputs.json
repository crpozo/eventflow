{
  "version": 1,
  "paths": {
    "/certificate-test": {
      "name": "/certificate-test",
      "lambdaFunction": "certificateSender",
      "permissions": {
        "setting": "private",
        "auth": [
          "create",
          "read",
          "update",
          "delete"
        ]
      }
    },
    "/users": {
      "name": "/users",
      "lambdaFunction": "userManager",
      "permissions": {
        "setting": "private",
        "auth": [
          "create",
          "read",
          "update",
          "delete"
        ]
      }
    }
  }
}