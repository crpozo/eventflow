{
  "version": 1,
  "serviceConfiguration": {
    "apiName": "eventflow",
    "serviceName": "AppSync",
    "defaultAuthType": {
      "mode": "API_KEY",
      "expirationTime": 365,
      "apiKeyExpirationDate": "2026-05-07T02:07:18.324Z",
      "keyDescription": "api key description"
    },
    "additionalAuthTypes": [
      {
        "mode": "AMAZON_COGNITO_USER_POOLS",
        "cognitoUserPoolId": "autheventflow"
      },
      {
        "mode": "AWS_IAM"
      }
    ],
    "conflictResolution": {
      "defaultResolutionStrategy": {
        "type": "AUTOMERGE"
      }
    }
  }
}